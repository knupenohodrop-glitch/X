# Host path to git repo root (must be a clone with remote for push). Mounted at DATA_ROOT in container.
WORKDIR_HOST=C:/path/to/your/data-repo

# Host directory with SSH keys for git push (typically contains id_ed25519 or id_rsa, known_hosts, config).
SSH_DIR=C:/Users/YourUser/.ssh

# Path inside container (mount target). Git + CSV data live here.
DATA_ROOT=/data
WORKDIR=/data

# Optional: override repo dir for git commands (empty = coinDataGatherer default: same as workdir).
# REPODIR=

# Leave empty to fetch pairs from Binance via binancepairlist; or set explicit list:
# PAIR_LIST=BTCUSDT,ETHUSDT
PAIR_LIST=

# Only use symbols whose quote asset matches (e.g. USDT). Empty = all rows in CSV.
PAIR_QUOTE=USDT

# Cap concurrent pairs (screen sessions). Use 0 for no limit.
MAX_PAIRS=50

PAIR_STATUS=TRADING
PAIRS_CSV=/data/pairs.csv

# BINANCE_BASE_URL=https://testnet.binance.vision

COINDG_DURATION=0
HTTP_TIMEOUT=10s

GIT_AUTO=1
GIT_REMOTE=origin
# GIT_BRANCH=main
GIT_COMMIT_EVERY=10m
GIT_COMMIT_PREFIX=data:
